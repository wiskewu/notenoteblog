    <title>TIL 2026/4/13 16:42:35</title>
    <link href="/til/new-function创建的iife/" />
    <id>/til/new-function创建的iife/</id>
    <updated>2026/4/13 16:42:35T00:00:00+08:00</updated>
    <content type="html">&lt;h2 id=&quot;new-function创建的iife&quot; tabindex=&quot;-1&quot;&gt;new function创建的IIFE&lt;/h2&gt;
&lt;p&gt;在&lt;a href=&quot;https://github.com/paperjs/paper.js/blob/92775f5279c05fb7f0a743e9e7fa02cd40ec1e70/src/dom/DomEvent.js#L83-L123&quot;&gt;paper.js-DomEvent&lt;/a&gt;源码中，存在以下代码（已简化）：&lt;/p&gt;
&lt;pre class=&quot;shiki shiki-themes github-light-default github-dark-default __shiki_c16w35&quot; tabindex=&quot;0&quot;&gt;&lt;code class=&quot;language-js&quot;&gt;&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;DomEvent.requestAnimationFrame &lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;=&lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt; new&lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt; function&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;() {&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;var&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt; nativeRequest &lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;=&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt; DomElement.&lt;/span&gt;&lt;span class=&quot;__shiki_2fxx5c&quot;&gt;getPrefixed&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;(window, &lt;/span&gt;&lt;span class=&quot;__shiki_50d5g0&quot;&gt;&apos;requestAnimationFrame&apos;&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;),&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;requested &lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;=&lt;/span&gt;&lt;span class=&quot;__shiki_1r536h&quot;&gt; false&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;,&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;callbacks &lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;=&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt; [],&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;timer;&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot; style=&quot;--indent-offset: 0ch;&quot;&gt;&lt;/span&gt;&lt;span class=&quot;indent&quot; style=&quot;--indent-offset: 2ch;&quot;&gt;&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;function&lt;/span&gt;&lt;span class=&quot;__shiki_2fxx5c&quot;&gt; handleCallbacks&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;() {&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_25oonp&quot;&gt;// 省略函数实现&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;}&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot; style=&quot;--indent-offset: 0ch;&quot;&gt;&lt;/span&gt;&lt;span class=&quot;indent&quot; style=&quot;--indent-offset: 2ch;&quot;&gt;&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;return&lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt; function&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;(&lt;/span&gt;&lt;span class=&quot;__shiki_1g8orr&quot;&gt;callback&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;) {&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_25oonp&quot;&gt;// 省略函数实现&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;};&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;};&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;
&lt;p&gt;然后在&lt;a href=&quot;https://github.com/paperjs/paper.js/blob/92775f5279c05fb7f0a743e9e7fa02cd40ec1e70/src/view/View.js#L225-L250&quot;&gt;paper.js-View&lt;/a&gt;中使用（已简化）：&lt;/p&gt;
&lt;pre class=&quot;shiki shiki-themes github-light-default github-dark-default __shiki_c16w35&quot; tabindex=&quot;0&quot;&gt;&lt;code class=&quot;language-js&quot;&gt;&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;DomEvent.&lt;/span&gt;&lt;span class=&quot;__shiki_2fxx5c&quot;&gt;requestAnimationFrame&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;(&lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;function&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;() {&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_25oonp&quot;&gt;// 省略函数实现&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;});&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;
&lt;p&gt;即&lt;code&gt;new function() { ... }&lt;/code&gt;是JS的一种立即执行模式，创建一个匿名构造函数并立即&lt;code&gt;new&lt;/code&gt;，但由于函数体显式&lt;code&gt;return&lt;/code&gt;了一个对象（这里是一个函数），所以&lt;code&gt;new&lt;/code&gt;的结果不是新构造的&lt;code&gt;this&lt;/code&gt;，而是&lt;code&gt;return&lt;/code&gt;的&lt;strong&gt;函数本身&lt;/strong&gt;。&lt;/p&gt;
&lt;p&gt;也就是说上述代码&lt;code&gt;DomEvent.requestAnimationFrame&lt;/code&gt;的值等于返回的函数&lt;code&gt;function(callback) { ... }&lt;/code&gt;。&lt;/p&gt;
&lt;p&gt;类似于下方代码：&lt;/p&gt;
&lt;pre class=&quot;shiki shiki-themes github-light-default github-dark-default __shiki_c16w35&quot; tabindex=&quot;0&quot;&gt;&lt;code class=&quot;language-js&quot;&gt;&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;function&lt;/span&gt;&lt;span class=&quot;__shiki_2fxx5c&quot;&gt; Me&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;() {&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_1r536h&quot;&gt;this&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;.name &lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;=&lt;/span&gt;&lt;span class=&quot;__shiki_50d5g0&quot;&gt; &apos;Me&apos;&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;;&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;}&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;function&lt;/span&gt;&lt;span class=&quot;__shiki_2fxx5c&quot;&gt; Person&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;() {&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_1r536h&quot;&gt;this&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;.name &lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;=&lt;/span&gt;&lt;span class=&quot;__shiki_50d5g0&quot;&gt; &apos;A&apos;&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;;&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;indent&quot;&gt;  &lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;return&lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt; new&lt;/span&gt;&lt;span class=&quot;__shiki_2fxx5c&quot;&gt; Me&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;();&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;}&lt;/span&gt;&lt;/span&gt;
&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;console.&lt;/span&gt;&lt;span class=&quot;__shiki_2fxx5c&quot;&gt;log&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;(&lt;/span&gt;&lt;span class=&quot;__shiki_13ief6&quot;&gt;new&lt;/span&gt;&lt;span class=&quot;__shiki_2fxx5c&quot;&gt; Person&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;().name); &lt;/span&gt;&lt;span class=&quot;__shiki_25oonp&quot;&gt;// &apos;Me&apos;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;
</content>
  </entry>
