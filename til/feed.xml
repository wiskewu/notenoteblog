&lt;pre class=&quot;shiki shiki-themes github-light-default github-dark-default __shiki_c16w35&quot; tabindex=&quot;0&quot;&gt;&lt;code class=&quot;language-cmd&quot;&gt;&lt;span class=&quot;line&quot;&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt;systeminfo | findstr /i /c:&lt;/span&gt;&lt;span class=&quot;__shiki_50d5g0&quot;&gt;&quot;物理内存总量&quot;&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt; /c:&lt;/span&gt;&lt;span class=&quot;__shiki_50d5g0&quot;&gt;&quot;可用的物理内存&quot;&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt; /c:&lt;/span&gt;&lt;span class=&quot;__shiki_50d5g0&quot;&gt;&quot;虚拟内存: 最大值&quot;&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt; /c:&lt;/span&gt;&lt;span class=&quot;__shiki_50d5g0&quot;&gt;&quot;虚拟内存: 可用&quot;&lt;/span&gt;&lt;span class=&quot;__shiki_1pf2xz&quot;&gt; /c:&lt;/span&gt;&lt;span class=&quot;__shiki_50d5g0&quot;&gt;&quot;虚拟内存: 使用中&quot;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;
